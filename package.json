{
  "name": "quorum",
  "version": "0.1.0",
  "description": "Business-facing evidence layer for enterprise AI agent claims.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": "./dist/src/index.js",
    "./cli": "./dist/src/cli.js"
  },
  "bin": {
    "quorum": "./dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "smoke": "node scripts/smoke-check.mjs",
    "status:refresh": "node scripts/update-status.mjs",
    "test": "node --import tsx --test tests/**/*.test.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "pdf-parse": "^2.4.5"
  }
}
